#!/bin/bash
set -euo pipefail

# Dependencies are installed at image build time (see Dockerfile).
# Keep this start script network-free and fast.

# Ensure Jupyter Server can import marimo_redirect from this repo
export PYTHONPATH="${PWD}:${PYTHONPATH:-}"

# Start marimo behind Jupyter's proxy
#
# IMPORTANT: In Binder/JupyterHub the user is already authenticated upstream
# (cookies + hub auth). If marimo also requires its own access token, the root
# redirect to /proxy/2718/ won't include it and the marimo UI will not load.
# Therefore we disable marimo's session-token auth here and rely on the Hub.
#
# Default to *app* mode on 2718.
#
# Dev mode remains available at /dev (served by a second marimo instance on 2719).
marimo run notebooks/algorithms/visualizing-embeddings.py --host 0.0.0.0 --port 2718 --headless --no-token &
marimo edit notebooks/algorithms/visualizing-embeddings.py --host 0.0.0.0 --port 2719 --headless --no-token &


# Hand off to the default CMD (jupyterhub singleuser / jupyter lab)
exec "$@"
